{
  "hosting": [
    {
      "target": "main",
      "public": ".",
      "predeploy": [
        "python3 scripts/check_firebase_hosting_surface.py"
      ],
      "ignore": [
        "firebase.json",
        ".firebaserc",
        "firestore.rules",
        "**/.*",
        "**/node_modules/**",
        "private/**",
        "scripts/**",
        "**/*.private.json",
        "GITHUB_PAGES_MAINTENANCE.md",
        "README.md"
      ],
      "headers": [
        {
          "source": "**/*.@(html|webmanifest|js|json|css|svg)",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "no-cache"
            }
          ]
        }
      ]
    },
    {
      "target": "konbini-radar",
      "public": "utilities/konbini-radar",
      "predeploy": [
        "python3 scripts/check_firebase_hosting_surface.py"
      ],
      "ignore": [
        "firebase.json",
        ".firebaserc",
        "firestore.rules",
        "**/.*",
        "**/node_modules/**",
        "private/**",
        "scripts/**",
        "**/*.private.json"
      ],
      "headers": [
        {
          "source": "**/*.@(html|webmanifest|js|json|css|svg)",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "no-cache"
            }
          ]
        }
      ]
    }
  ],
  "firestore": {
    "rules": "firestore.rules"
  },
  "storage": {
    "rules": "storage.rules"
  }
}
